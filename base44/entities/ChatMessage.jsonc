{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "is_admin": {
      "type": "boolean",
      "default": false
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "conversation_id": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "message"
  ]
}