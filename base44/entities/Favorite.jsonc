{
  "name": "Favorite",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    }
  },
  "required": [
    "user_email",
    "product_id"
  ],
  "rls": {
    "create": {
      "data.user_email": "{{user.email}}"
    },
    "read": {
      "data.user_email": "{{user.email}}"
    },
    "update": {
      "data.user_email": "{{user.email}}"
    },
    "delete": {
      "data.user_email": "{{user.email}}"
    }
  }
}